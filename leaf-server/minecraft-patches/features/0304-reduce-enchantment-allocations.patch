From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: hayanesuru <hayanesuru@outlook.jp>
Date: Thu, 19 Mar 2026 20:11:58 +0900
Subject: [PATCH] reduce enchantment allocations

reduce allocation of creating entity loot contexts and unmodifiable set boxing

diff --git a/net/minecraft/world/item/enchantment/Enchantment.java b/net/minecraft/world/item/enchantment/Enchantment.java
index 05d9626aec8b66f5b02e875ad60b853d15c0e02a..960bbeb6854556ff25962a16240fcb95db40236f 100644
--- a/net/minecraft/world/item/enchantment/Enchantment.java
+++ b/net/minecraft/world/item/enchantment/Enchantment.java
@@ -202,9 +202,15 @@ public record Enchantment(Component description, Enchantment.EnchantmentDefiniti
     }
 
     public boolean isImmuneToDamage(ServerLevel level, int enchantmentLevel, Entity entity, DamageSource damageSource) {
+        // Leaf start - reduce enchantment allocations
+        List<ConditionalEffect<DamageImmunity>> damageImmunityEffects = this.getEffects(EnchantmentEffectComponents.DAMAGE_IMMUNITY);
+        if (damageImmunityEffects.isEmpty()) {
+            return false;
+        }
+        // Leaf end - reduce enchantment allocations
         LootContext lootContext = damageContext(level, enchantmentLevel, entity, damageSource);
 
-        for (ConditionalEffect<DamageImmunity> conditionalEffect : this.getEffects(EnchantmentEffectComponents.DAMAGE_IMMUNITY)) {
+        for (ConditionalEffect<DamageImmunity> conditionalEffect : damageImmunityEffects) { // Leaf - reduce enchantment allocations
             if (conditionalEffect.matches(lootContext)) {
                 return true;
             }
@@ -349,8 +355,14 @@ public record Enchantment(Component description, Enchantment.EnchantmentDefiniti
     }
 
     public void tick(ServerLevel level, int enchantmentLevel, EnchantedItemInUse item, Entity entity) {
+        // Leaf start - reduce enchantment allocations
+        List<ConditionalEffect<EnchantmentEntityEffect>> tickEffects = this.getEffects(EnchantmentEffectComponents.TICK);
+        if (tickEffects.isEmpty()) {
+            return;
+        }
         applyEffects(
-            this.getEffects(EnchantmentEffectComponents.TICK),
+            tickEffects,
+        // Leaf end - reduce enchantment allocations
             entityContext(level, enchantmentLevel, entity, entity.position()),
             enchantmentEntityEffect -> enchantmentEntityEffect.apply(level, enchantmentLevel, item, entity, entity.position())
         );
diff --git a/net/minecraft/world/item/enchantment/EnchantmentHelper.java b/net/minecraft/world/item/enchantment/EnchantmentHelper.java
index 373e3b9017433939512493558b4e0fe32a865b56..2677f911d33441b3d0eacc703a372de05d89acf1 100644
--- a/net/minecraft/world/item/enchantment/EnchantmentHelper.java
+++ b/net/minecraft/world/item/enchantment/EnchantmentHelper.java
@@ -131,7 +131,7 @@ public class EnchantmentHelper {
     private static void runIterationOnItem(ItemStack stack, EnchantmentHelper.EnchantmentVisitor visitor) {
         ItemEnchantments itemEnchantments = stack.getOrDefault(DataComponents.ENCHANTMENTS, ItemEnchantments.EMPTY);
 
-        for (Entry<Holder<Enchantment>> entry : itemEnchantments.entrySet()) {
+        for (Entry<Holder<Enchantment>> entry : itemEnchantments.keila$entrySet()) { // Leaf - reduce enchantment allocations
             visitor.accept(entry.getKey(), entry.getIntValue());
         }
     }
@@ -142,7 +142,7 @@ public class EnchantmentHelper {
             if (itemEnchantments != null && !itemEnchantments.isEmpty()) {
                 EnchantedItemInUse enchantedItemInUse = new EnchantedItemInUse(stack, slot, entity);
 
-                for (Entry<Holder<Enchantment>> entry : itemEnchantments.entrySet()) {
+                for (Entry<Holder<Enchantment>> entry : itemEnchantments.keila$entrySet()) { // Leaf - reduce enchantment allocations
                     Holder<Enchantment> holder = entry.getKey();
                     if (holder.value().matchingSlot(slot)) {
                         visitor.accept(holder, entry.getIntValue(), enchantedItemInUse);
diff --git a/net/minecraft/world/item/enchantment/ItemEnchantments.java b/net/minecraft/world/item/enchantment/ItemEnchantments.java
index b666181af7d6663f2fce58a7d9a4c805687f5409..5de7356f0375f9acf772ef457c477de0539fd092 100644
--- a/net/minecraft/world/item/enchantment/ItemEnchantments.java
+++ b/net/minecraft/world/item/enchantment/ItemEnchantments.java
@@ -99,6 +99,12 @@ public class ItemEnchantments implements TooltipProvider {
         return Collections.unmodifiableSet(this.enchantments.object2IntEntrySet());
     }
 
+    // Leaf start - reduce enchantment allocations
+    public it.unimi.dsi.fastutil.objects.ObjectSortedSet<Entry<Holder<Enchantment>>> keila$entrySet() {
+        return this.enchantments.object2IntEntrySet();
+    }
+    // Leaf end - reduce enchantment allocations
+
     public int size() {
         return this.enchantments.size();
     }
