Subject: [PATCH] Optimize pushable selector

Avoid duplicated Bukkit#isPushable check, already checked inside the Bukkit#canCollideWithBukkit

diff --git a/net/minecraft/world/entity/EntitySelector.java b/net/minecraft/world/entity/EntitySelector.java
index a0d23f7c733c315a021e8b2ba8968f41807159a4..27dc55aa3c2c18a9ade591cf094216736049a44c 100644
--- a/net/minecraft/world/entity/EntitySelector.java
+++ b/net/minecraft/world/entity/EntitySelector.java
@@ -48,10 +48,9 @@ public final class EntitySelector {
         Team team = entity.getTeam();
         Team.CollisionRule collisionRule = team == null ? Team.CollisionRule.ALWAYS : team.getCollisionRule();
         return (Predicate<Entity>)(collisionRule == Team.CollisionRule.NEVER
-            ? Predicates.alwaysFalse()
-            : NO_SPECTATORS.and(
-                entity1 -> { final Entity pushedEntity = entity1; // Paper - OBFHELPER
-                    if (!pushedEntity.isPushable() || !pushedEntity.canCollideWithBukkit(entity) || !entity.canCollideWithBukkit(pushedEntity)) { // CraftBukkit - collidable API // Paper - Climbing should not bypass cramming gamerule
+            ? Predicates.<Entity>alwaysFalse() // Leaf - optimize pushable selector
+            : (Predicate<Entity>) (entity1) -> { final Entity pushedEntity = entity1; // Paper - OBFHELPER // Leaf - optimize pushable selector
+                    if (entity1.isSpectator() /*|| !pushedEntity.isPushable()*/ || !pushedEntity.canCollideWithBukkit(entity) || !entity.canCollideWithBukkit(pushedEntity)) { // CraftBukkit - collidable API // Paper - Climbing should not bypass cramming gamerule // Leaf - optimize pushable selector
                         return false;
                     } else if (!entity.level().isClientSide() || entity1 instanceof Player player && player.isLocalPlayer()) {
                         Team team1 = entity1.getTeam();
@@ -67,7 +66,7 @@ public final class EntitySelector {
                         return false;
                     }
                 }
-            ));
+            ); // Leaf - optimize pushable selector
     }
 
     public static Predicate<Entity> notRiding(Entity entity) {
