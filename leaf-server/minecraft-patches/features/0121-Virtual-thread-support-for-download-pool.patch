diff --git a/net/minecraft/util/Util.java b/net/minecraft/util/Util.java
index 617f3804e9bd494c85915a60e05b8dd453c4c03c..b939f1807aaada171767bdfe5d63d7b950310bfb 100644
--- a/net/minecraft/util/Util.java
